#.gitignore file for a.NET 8 Umbraco Package Project

# User-specific files generated by Visual Studio
*.suo
*.user
*.userosscache
*.sln.docstates

# The Visual Studio metadata folder. This is the cause of your permission errors.
# This folder is user-specific and should never be in source control.
.vs/

# Build results
in/
[Oo]bj/

# Umbraco-specific files and folders to ignore
# These contain temporary data, caches, and logs that are specific to a local installation.
umbraco/Data/TEMP/
umbraco/Logs/
umbraco/Licenses/

# Don't commit the Umbraco website folder within the package source.
# This is only for the local test site and not part of the distributable package.
/Breez.Monetization.Web/

# Rider IDE specific files
.idea/

# Files generated by the.NET CLI
project.lock.json
project.assets.json
*.nuget.props
*.nuget.targets

# NuGet packages folder
packages/
*.nupkg
# Exclude packages folder from projects that use packages.config
**/packages/*
# Don't commit the NuGet HTTP cache
%APPDATA%/NuGet/Cache
%APPDATA%/NuGet/v3-cache

# Windows-specific files
Thumbs.db
ehthumbs.db
esktop.ini

# Log and temporary files
*.log
*.tmp
*.bak

# Node.js dependencies (for frontend build process)
node_modules/
npm-debug.log
yarn-error.log

# Frontend build output (if not in wwwroot of the RCL)
dist/